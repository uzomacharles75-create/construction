# --- SERVER CONFIGURATION ---
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# --- DATABASE (MongoDB Atlas) ---
# Code reads MONGO_URI (see src/server.ts)
MONGO_URI=mongodb+srv://[username]:[password]@[cluster].mongodb.net/buildhub?retryWrites=true&w=majority

# --- SECURITY (JWT) ---
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=7d

# --- EMAIL (Nodemailer) ---
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=465
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM="BuildHub Service <no-reply@buildhub.com>"
EMAIL_SECURE=true

# --- FILE STORAGE (Cloudinary) ---
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# --- AI (Google Gemini) ---
# Powers both the chat assistant (aiController.ts) and BOQ pricing (aiService.ts)
GEMINI_API_KEY=your_gemini_api_key

# --- JOB LISTINGS (JSearch via RapidAPI) — optional, powers the Opportunities feed ---
# Subscribe to the JSearch "Basic" (free) plan on RapidAPI, then paste the key here.
JSEARCH_API_KEY=your_rapidapi_jsearch_key

# --- SWYCHR / ACCOUNTPE PAYMENT GATEWAY ---
SWYCHR_EMAIL=your_accountpe_email
SWYCHR_PASSWORD=your_accountpe_password
SWYCHR_WEBHOOK_SECRET=your_webhook_secret
BACKEND_URL=https://your-api-domain.com/api/v1
FRONTEND_URL=https://your-frontend-domain.com
SWYCHR_ALLOW_INSECURE_TLS=false
