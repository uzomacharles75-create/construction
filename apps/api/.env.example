# --- SERVER CONFIGURATION ---
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# --- DATABASE (MongoDB Atlas) ---
# Replace with your actual connection string from MongoDB Atlas
MONGO_URI=mongodb+srv://[username]:[password]@[cluster].mongodb.net/buildhub?retryWrites=true&w=majority

# --- SECURITY (JWT) ---
# Use a long random string for the secret
JWT_SECRET=buildhub_super_secret_key_2024_africa_platform
JWT_EXPIRES_IN=7d

# --- AI ASSISTANT (OpenAI) ---
# Get this from platform.openai.com
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
GEMINI_API_KEY=your_gemini_api_key

# --- FILE STORAGE (Cloudinary) ---
# Get these from your Cloudinary Dashboard
CLOUDINARY_NAME=your_cloud_name
CLOUDINARY_KEY=your_api_key
CLOUDINARY_SECRET=your_api_secret
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# --- SWYCHR / ACCOUNTPE PAYMENT GATEWAY ---
# Sign up at https://accountpe.com and get credentials
SWYCHR_EMAIL=your_accountpe_email
SWYCHR_PASSWORD=your_accountpe_password
# Secret for validating inbound webhooks (set in AccountPe dashboard)
SWYCHR_WEBHOOK_SECRET=your_webhook_secret
# Your deployed API base URL (no trailing slash, no /api)
BACKEND_URL=https://your-api-domain.com/api/v1
# Your deployed frontend URL
FRONTEND_URL=https://your-frontend-domain.com
# Set to true only during local dev with self-signed TLS (never in production)
SWYCHR_ALLOW_INSECURE_TLS=false

# --- POCKET-BASE / ADDITIONAL SERVICES (Optional) ---
# If you plan to use email notifications later
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
